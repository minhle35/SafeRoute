# ─────────────────────────────────────────────────────────────────────────────
# SafeRoute — VicRoads Secure AI Gateway
# Environment configuration template
#
# Usage:
#   cp .env.template .env
#   Fill in the required values marked with <...>
#   Never commit .env — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_NAME="SafeRoute"
APP_VERSION="0.1.0"

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Developer auth ────────────────────────────────────────────────────────────
# Requests must include header: X-Developer-Token: dev-<anything>
AUTH_HEADER_NAME=X-Developer-Token
DEV_TOKEN_PREFIX=dev-

# ── LLM routing (OpenRouter) ──────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Sent as HTTP-Referer / X-Title to OpenRouter for dashboard attribution
OR_SITE_URL=https://vicroads-ai-gateway.internal
OR_APP_NAME="VicRoads SafeRoute"

# Default model — must include the openrouter/ prefix for LiteLLM routing
# Free options: openrouter/meta-llama/llama-3.1-8b-instruct:free
#               openrouter/google/gemma-3-4b-it:free
DEFAULT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free

LLM_TIMEOUT=300       # seconds before request is abandoned
LLM_MAX_TOKENS=1600   # maximum prompt token count allowed per request

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero setup for local dev):
DATABASE_URL=sqlite+aiosqlite:///./saferoute.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/saferoute

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=app.log

# ── SpaCy NER model ───────────────────────────────────────────────────────────
# en_core_web_sm: 12 MB, 80–150 ms/request  (default, recommended)
# en_core_web_lg: 560 MB, 300–500 ms/request (higher NER accuracy)
SPACY_MODEL=en_core_web_sm
